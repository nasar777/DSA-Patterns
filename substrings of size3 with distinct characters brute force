class Solution {
    public int countGoodSubstrings(String s) {
        HashSet<Character> hs=new HashSet<>();
        int n=s.length();
        int sl=3;
        int cnt=0;
        for(int i=0;i<=n-sl;i++){
            int j=i+sl-1;
            for(int k=i;k<=j;k++){
                char ch=s.charAt(k);
                hs.add(ch);
            }

            if(hs.size()==3){
                cnt++;
            }
            hs.clear();
        }
        return cnt;
    }
}
t.c=O(n)
s.c=o(1)
